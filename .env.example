# FareGuard Environment Configuration
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development
HOST=localhost

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Database
DB_PATH=./data/fareguard.db

# Cloud Storage (S3-compatible)
CLOUD_STORAGE_ENDPOINT=http://localhost:9000
CLOUD_STORAGE_BUCKET=fareguard-data
CLOUD_STORAGE_ACCESS_KEY=minioadmin
CLOUD_STORAGE_SECRET_KEY=minioadmin

# Simulation Configuration
SIM_DAYS=90
SIM_ROUTES_SUBSET=50
SIM_ANOMALY_RATE=0.05
SIM_TIME_ACCELERATION=100

# ML Configuration
ML_MODEL_PATH=./models
ML_RETRAIN_INTERVAL_HOURS=24

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/fareguard.log

# Streaming / Pub-Sub
STREAM_BATCH_SIZE=100
STREAM_FLUSH_INTERVAL_MS=5000
DEAD_LETTER_PATH=./data/dead-letter

# Monitoring
MONITOR_ENABLED=true
MONITOR_INTERVAL_MS=60000
